<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GateWay.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:color="clr-namespace:ColorPalette"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="GateWay.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="None"
        Height="1200" Width="1200"
        MinWidth="500" MinHeight="500"
        Icon="/Assets/GateWay_logo.ico"
        Title="GateWay">
    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <ImageBrush Source="avares://GateWay/Assets/Background.jpg" Stretch="UniformToFill" x:Key="BgBrush"/>
    </Window.Resources>

    <Window.Styles>
        <!-- Top Bar Controls -->
        <Style Selector="Label.TopRowStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Label.TopRowStyle:pointerover">
            <Setter Property="Background" Value="{Binding Source={x:Static color:ColorPaletteNebula.HighlightColor}}"/>
        </Style>
        <Style Selector="Label.TopRowStyle:pressed">
            <Setter Property="Background" Value="{Binding Source={x:Static color:ColorPaletteNebula.PressColor}}"/>
        </Style>

        <!-- Side Pane & Interactive Labels -->
        <Style Selector="Label.SidePaneStyle">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Label.SidePaneStyle:pointerover">
            <Setter Property="Background" Value="{Binding Source={x:Static color:ColorPaletteNebula.HighlightColor}}"/>
        </Style>
        <Style Selector="Label.SidePaneStyle:pressed">
            <Setter Property="Background" Value="{Binding Source={x:Static color:ColorPaletteNebula.PressColor}}"/>
        </Style>

        <!-- ScrollViewer Base -->
        <Style Selector="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" MaxHeight="40" MinHeight="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Title Bar -->
        <Grid Grid.Row="0" Background="{Binding Source={x:Static color:ColorPaletteNebula.HorBarGradient}}">
            <TextBlock Text="GateWay" FontSize="14" FontWeight="SemiBold" Foreground="White"
                       VerticalAlignment="Center" Margin="16,0,0,0" Opacity="0.9"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                <Label x:Name="BtnToTray" Classes="TopRowStyle" PointerPressed="BtnToTray_OnClick">
                    <Label.Content>
                        <TextBlock Text="−" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Label.Content>    
                </Label>
                <Label x:Name="BtnFullscreen" Classes="TopRowStyle" PointerPressed="BtnFullscreen_OnClick">
                    <Label.Content>
                        <TextBlock Text="□" FontSize="18" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Label.Content>
                </Label>
                <Label x:Name="BtnClose" Classes="TopRowStyle" PointerPressed="BtnClose_OnClick">
                    <Label.Content>
                        <TextBlock Text="✕" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Medium"/>
                    </Label.Content>
                </Label>
            </StackPanel>
        </Grid>

        <!-- Unlogged UI -->
        <UserControl Grid.Row="1" Name="UserLogged">
            <Grid Name="ContentGrid" Background="{Binding Source={x:Static color:ColorPaletteNebula.BackgroundColor}}" ClipToBounds="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Navigation + Chat List -->
                <Grid Grid.Column="0">
                    <!-- Side Pane -->
                    <SplitView x:Name="SidePane" VerticalAlignment="Stretch" HorizontalAlignment="Left"
                               CornerRadius="12" PaneBackground="{Binding Source={x:Static color:ColorPaletteNebula.VertBarGradient}}"
                               DisplayMode="CompactInline" IsPaneOpen="False" CompactPaneLength="50" OpenPaneLength="280" ZIndex="10">
                        <SplitView.Pane>
                            <StackPanel Orientation="Vertical" Spacing="10">
                                <Label x:Name="PaneExpand" PointerPressed="PaneExpand_OnClick" Classes="SidePaneStyle"
                                       Width="44" Height="44" HorizontalAlignment="Left" Margin="4,4,4,12">
                                    <TextBlock Text="☰" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Label>
                                <StackPanel x:Name="PaneContent" Orientation="Vertical" VerticalAlignment="Top"
                                            IsEnabled="False" IsVisible="False" Spacing="4">
                                    <Separator Background="{Binding Source={x:Static color:ColorPaletteNebula.ChatCloudColor}}" Opacity="0.4" Margin="8,4"/>
                                    <Label x:Name="AddChatBtn" Classes="SidePaneStyle" HorizontalAlignment="Stretch" Height="44">
                                        <TextBlock Text="➕ Добавить чат" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" FontWeight="Medium"/>
                                    </Label>
                                    <Label x:Name="LogoutLabel" Classes="SidePaneStyle" HorizontalAlignment="Stretch" Height="44">
                                        <TextBlock Text="🚪 Выйти" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" FontWeight="Medium"/>
                                    </Label>
                                </StackPanel>
                            </StackPanel>
                        </SplitView.Pane>
                        <SplitView.Content>
                            <Border Background="Transparent"/>
                        </SplitView.Content>
                    </SplitView>

                    <!-- Chat List -->
                    <Border Margin="55,10,5,10" Background="{Binding Source={x:Static color:ColorPaletteNebula.BackgroundColor}}"
                            CornerRadius="12" BorderBrush="{Binding Source={x:Static color:ColorPaletteNebula.SummerSurfColor}}" BorderThickness="1" Opacity="0.8">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" Padding="4">
                            <StackPanel x:Name="ChatList" Spacing="6" Margin="0,5"/>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Vertical Separator -->
                <Border Grid.Column="1" Width="1" Background="{Binding Source={x:Static color:ColorPaletteNebula.SummerSurfColor}}"
                        Opacity="0.3" Margin="0,15"/>

                <!-- Right Panel: Messages -->
                <Border Grid.Column="2" Margin="10,10,10,10" Background="{Binding Source={x:Static color:ColorPaletteNebula.BackgroundColor}}"
                        CornerRadius="12" BorderBrush="{Binding Source={x:Static color:ColorPaletteNebula.SummerSurfColor}}" BorderThickness="1" Opacity="0.85">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="15">
                        <StackPanel x:Name="StackMessages" Spacing="8" HorizontalAlignment="Stretch"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </UserControl>

        <!-- Login Screen -->
        <UserControl Grid.Row="1" Name="LoginScreen" Background="{StaticResource BgBrush}">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Добро пожаловать!" TextWrapping="Wrap" FontSize="36" FontWeight="ExtraBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center" 
                           Foreground="{Binding Source={x:Static color:ColorPaletteNebula.GlacierMistColor}}"/>

                <TextBlock Grid.Row="2" Text="Вы не имеете локального аккаунта. Нажмите ниже, чтобы создать его.&#10;Мы не используем сторонние сервисы."
                           FontSize="18" Name="GreetingText" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontWeight="DemiBold" Foreground="{Binding Source={x:Static color:ColorPaletteNebula.SummerSurfColor}}" Opacity="0.9" TextAlignment="Center"/>

                <Label Grid.Row="4" x:Name="CreateUserLabel" Margin="0,10,0,0" Padding="18,14" CornerRadius="10"
                       Background="{Binding Source={x:Static color:ColorPaletteNebula.ChatCloudColor}}" Cursor="Hand"
                       PointerEntered="CreateUserLabel_OnPointerEntered" PointerExited="CreateUserLabel_OnPointerExited" PointerPressed="CreateUserLabel_OnPointerPressed"
                       HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Поехали →" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" 
                               Foreground="{Binding Source={x:Static color:ColorPaletteNebula.BackgroundColor}}"/>
                </Label>
            </Grid>
        </UserControl>
    </Grid>
</Window>
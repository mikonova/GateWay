<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GateWay.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="GateWay.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="None"
        Icon="/Assets/GateWay_logo.ico"
        Title="GateWay">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    <Window.Styles>
        
        <Style Selector="Label.TopRowStyle">
            <Setter Property="Background" Value="#59518c" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
        </Style>
        
        <Style Selector="Label.TopRowStyle:pointerover">
            <Setter Property="Background" Value="#6d65a1"/>
        </Style>
        
        <Style Selector="Label.TopRowStyle:pressed">
            <Setter Property="Background" Value="#7e78ab"/>
        </Style>
        
        <Style Selector="Label.SidePaneStyle:pointerover">
            <Setter Property="Background" Value="#40f5f5f5" />
        </Style>
        
        <Style Selector="Label.SidePaneStyle">
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
        </Style>
        
    </Window.Styles>
    <!--Viewbox Stretch="Uniform"-->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition MaxHeight="40" MinHeight="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid HorizontalAlignment="Stretch" Background="#191725">
                <WrapPanel Background="Transparent" HorizontalAlignment="Right">
                    <Label 
                        x:Name="BtnToTray" 
                        HorizontalAlignment="Right"
                        Classes="TopRowStyle"
                        PointerPressed="BtnToTray_OnClick">
                            <TextBlock Text="-" FontSize="20" VerticalAlignment="Center" TextAlignment="Center"/>
                        </Label>
                        <Label 
                            Classes="TopRowStyle"
                            PointerPressed="BtnFullscreen_OnClick"
                            HorizontalAlignment="Right">
                            <TextBlock x:Name="BtnFullscreen"  Text="□" FontSize="14" VerticalAlignment="Center" TextAlignment="Center"/>
                        </Label>
                        <Label 
                            x:Name="BtnClose" 
                            HorizontalAlignment="Right"
                            Classes="TopRowStyle"
                            PointerPressed="BtnClose_OnClick">
                            <TextBlock Text="x" FontSize="20" VerticalAlignment="Center" TextAlignment="Center"/>
                        </Label>
                </WrapPanel>
            </Grid>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <SplitView 
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Left"
                    x:Name="SidePane" 
                    CornerRadius="12"
                    Background="#59518c" 
                    PaneBackground="#59518c"
                    DisplayMode= "CompactOverlay"
                    IsPaneOpen="False"
                    OpenPaneLength="300">
                    <SplitView.Pane>
                        <StackPanel>
                            <Label 
                                   x:Name="PaneExpand"
                                   PointerPressed="PaneExpand_OnClick"
                                   Classes="SidePaneStyle"
                                   FontSize="30"
                                   HorizontalAlignment="Left">
                                <TextBlock 
                                    Text="☰" 
                                    FontSize="35" 
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Label>
                        </StackPanel>
                    </SplitView.Pane>
                    <SplitView.Content>
                        
                    </SplitView.Content>
                </SplitView>
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        
                    </StackPanel>
                </Grid>
            </Grid>
            
        </Grid>
    <!--/Viewbox-->

</Window>
